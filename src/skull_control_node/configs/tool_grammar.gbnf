array ::= "[" space ( value ("," space value)* )? "]" space
boolean ::= ("true" | "false") space
char ::= [^"\\\x7F\x00-\x1F] | [\\] (["\\bfnrt] | "u" [0-9a-fA-F]{4})
decimal-part ::= [0-9]{1,16}
final-output-kv ::= "\"final_output\"" space ":" space string
integral-part ::= [0] | [1-9] [0-9]{0,15}
null ::= "null" space
number ::= ("-"? integral-part) ("." decimal-part)? ([eE] [-+]? integral-part)? space
object ::= "{" space ( string ":" space value ("," space string ":" space value)* )? "}" space
root ::= "{" space thoughts-kv "," space tool-calls-kv "," space final-output-kv "}" space
space ::= | " " | "\n"{1,2} [ \t]{0,20}
string ::= "\"" char* "\"" space
thoughts-kv ::= "\"thoughts\"" space ":" space string
tool-calls ::= "[" space (tool-calls-item ("," space tool-calls-item)*)? "]" space
tool-calls-item ::= tool-calls-item-0
tool-calls-item-0 ::= object
tool-calls-kv ::= "\"tool_calls\"" space ":" space tool-calls
value ::= object | array | string | number | boolean | null
